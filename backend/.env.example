# ============================================================
# StrangerChat Backend — Environment Variables
# Copy to .env and fill in real values.
# ============================================================

NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://strangerchat:strangerchat@localhost:5432/strangerchat?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Client / CORS ---
CLIENT_URL="http://localhost:3000"
# COOKIE_DOMAIN=.strangerchat.app

# --- JWT (CHANGE THESE IN PRODUCTION; min 16 chars each) ---
JWT_ACCESS_SECRET="change_me_access_secret_min_16_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_16_chars"
ACCESS_TTL="15m"
REFRESH_TTL_DAYS=30

# --- Google OAuth (optional; enables Google login) ---
GOOGLE_CLIENT_ID=""

# --- Razorpay (optional; enables card/netbanking/UPI auto-verify) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- UPI (static VPA QR) ---
UPI_ID="jainilmaru10thb@oksbi"
UPI_NAME="StrangerChat"

# --- WebRTC ICE ---
STUN_URLS="stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302"
TURN_URL="turn:localhost:3478"
TURN_USERNAME="strangerchat"
TURN_CREDENTIAL="strangerchat_turn_secret"

# --- Free tier filter allowance (seconds/day) ---
FREE_FILTER_SECONDS=180

# --- SMTP (optional; if unset, OTP/reset emails are logged to console) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="StrangerChat <no-reply@strangerchat.app>"
